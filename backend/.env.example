# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/student_attendance?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# QR Code
QR_ROTATION_INTERVAL_SECONDS=30
QR_SESSION_SECRET="your-qr-session-secret-change-this"

# Location
MAX_CHECKIN_DISTANCE_METERS=50

# Firebase (optional - for push notifications)
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""
